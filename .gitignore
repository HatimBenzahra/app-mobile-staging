# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
node_modules/
.expo/
dist/
build/
.env
.env.*
# Exceptions : configs d'env versionnees (URL backend uniquement, AUCUN secret)
!.env.staging
!.env.production
.DS_Store

# APK builds
*.apk

# EAS config (contains secrets)
eas.json

# OMC : etat runtime volatile (ne PAS versionner — source du churn de commits)
.omc/state/
.omc/sessions/
.omc/logs/
.omc/project-memory.json
# (on garde .omc/plans/ versionne : ce sont des docs utiles)

# .omc parasites poses dans assets/ (ceux d'android/ sont deja ignores via /android)
assets/**/.omc/

# Backups manuels de config
*.staging-bak